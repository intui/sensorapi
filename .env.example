# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sensor_api

# TimescaleDB Configuration (if using)
TIMESCALE_DATABASE_URL=postgresql://username:password@your-timescale-host:port/database

# Application Configuration
APP_NAME=SensorAPI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# API Configuration
API_PREFIX=/api/v1
GRAPHQL_ENDPOINT=/graphql
API_HOST=localhost
API_PORT=8000

# Security (CRITICAL: Generate strong secrets for production)
SECRET_KEY=your-super-secret-jwt-key-here-make-it-long-and-random
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Production Settings
PRODUCTION=false

# Optional: External Service API Keys
# WEATHER_API_KEY=your-weather-service-key
# NOTIFICATION_SERVICE_KEY=your-notification-service-key

# Security Notes:
# - Generate JWT secrets using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - Use your database provider's tools to generate secure passwords
# - Never commit .env file to version control
# - Rotate all credentials before making repository public
