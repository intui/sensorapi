{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/graphql",
      "destination": "/api/main"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/main"
    },
    {
      "source": "/health",
      "destination": "/api/main"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
